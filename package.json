{
  "name": "@gearbox-protocol/safe-watcher",
  "version": "1.0.0",
  "author": "doomsower <12031673+doomsower@users.noreply.github.com>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "module": "dist/index.mjs",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "node esbuild.mjs",
    "start": "touch .env && sh -c 'tsx --env-file .env src/index.ts \"$@\" | pino-pretty --colorize' --",
    "prepare": "husky",
    "prettier": "prettier --write .",
    "prettier:ci": "npx prettier --check .",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "lint:ci": "eslint \"src/**/*.ts\"",
    "typecheck:ci": "tsc --noEmit",
    "test": "npx jest --coverage --watchAll=false || exit 0",
    "test:watch": "npx jest --coverage --watch"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.946.0",
    "@aws-sdk/client-secrets-manager": "^3.946.0",
    "@rsksmart/rsk-utils": "^2.0.5",
    "@slack/types": "^2.19.0",
    "@slack/web-api": "^7.13.0",
    "@types/tmp": "^0.2.6",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vlad-yakovlev/telegram-md": "^2.1.0",
    "abitype": "^1.2.1",
    "date-fns": "^4.1.0",
    "nanoid": "^5.1.6",
    "pino": "^10.1.0",
    "tmp": "^0.2.5",
    "viem": "^2.41.2",
    "yaml": "^2.8.2",
    "zod": "^4.2.1",
    "zod-config": "^1.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.3",
    "esbuild": "^0.27.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "fetch-mock": "^12.6.0",
    "husky": "^9.0.11",
    "jest": "^30.1.3",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.4",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": "prettier --write"
  },
  "jest": {
    "testEnvironment": "node",
    "preset": "ts-jest",
    "moduleNameMapper": {
      "^(\\.\\.?\\/.+)\\.jsx?$": "$1"
    },
    "collectCoverageFrom": [
      "src/aws/*.ts",
      "src/safe-hashes/*.ts",
      "src/safe/*.ts",
      "src/config/*.ts",
      "src/utils/*.ts",
      "src/index.ts",
      "src/SafeWatcher.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 90,
        "lines": 90,
        "statements": 95
      }
    }
  },
  "packageManager": "yarn@4.6.0"
}
